{
  "name": "petty-cash-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node ./scripts/run-expo.js start",
    "android": "node ./scripts/run-expo.js start --android",
    "ios": "node ./scripts/run-expo.js start --ios",
    "web": "node ./scripts/run-expo.js start --web",
    "test": "jest",
    "build:web": "expo export --platform web --output-dir web-dist",
    "build:web:vercel": "expo export --platform web --output-dir web-dist-vercel",
    "deploy:firebase": "firebase-tools deploy --only hosting,firestore:rules,storage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@supabase/supabase-js": "^2.57.4",
    "expo": "~53.0.9",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.7",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "~18.1.11",
    "expo-image-picker": "~16.1.4",
    "expo-notifications": "~0.31.5",
    "expo-print": "~14.1.4",
    "expo-sharing": "~13.1.5",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "firebase": "^12.12.1",
    "papaparse": "^5.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.14",
    "react-test-renderer": "^19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  }
}
